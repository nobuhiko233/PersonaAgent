# ==========================================
# PersonaAgent 环境变量配置模板 (.env.example)
# ==========================================
# 使用说明：
# 1. 复制本文件并重命名为 .env
# 2. 将下方带有 <...> 的占位符替换为你本地真实的路径或 API Key

# ------------------------------------------
# 1. 大模型配置
# ------------------------------------------
# 你的 DeepSeek API Key (以 sk- 开头)
DEEPSEEK_API_KEY=<your_deepseek_api_key_here>

# ------------------------------------------
# 2. LangSmith 链路追踪配置 (用于评测与调试)
# ------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# 你的 LangSmith API Key
LANGCHAIN_API_KEY=<your_langsmith_api_key_here>
LANGCHAIN_PROJECT=PersonaAgent

# ------------------------------------------
# 3. Hugging Face 本地化配置
# ------------------------------------------
# 你的本地模型下载缓存目录
HF_HOME=<your_huggingface_cache_dir_here>
# 国内加速镜像源
HF_ENDPOINT=https://hf-mirror.com
# 强制离线模式开关 (0 为开启网络下载，1 为强制仅使用本地缓存)
HF_HUB_OFFLINE=1

# ------------------------------------------
# 4. RAG 向量模型配置
# ------------------------------------------
# Embedding 模型的本地物理绝对路径 (指向 snapshots 下的一串哈希文件夹)
EMBEDDING_MODEL_PATH=<your_embedding_model_absolute_path_here>

# ------------------------------------------
# 5. MCP (Machine Context Protocol) 外部工具配置
# ------------------------------------------
# uv.exe 环境的绝对路径
MCP_UV_PATH=<your_uv_exe_path_here>
# Bangumi MCP 项目所在的绝对路径
MCP_BANGUMI_PATH=<your_bangumi_mcp_directory_here>